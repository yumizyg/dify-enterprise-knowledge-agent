# Dify 后端（二选一）

# 方式 A：API 代理（推荐，自定义聊天界面）
# Dify 应用 → 发布 → API 访问 → 创建 API Key
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
# 自托管 Dify 请改为你的域名，例如 https://dify.example.com/v1
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_APP_NAME=企业内部知识库 Agent

# 方式 B：iframe 嵌入（若已在 Dify 发布 WebApp 并获取分享链接）
# 设置后将直接使用 Dify 官方对话页，优先级高于 API Key
# DIFY_EMBED_URL=https://udify.app/chat/xxxxxxxx
